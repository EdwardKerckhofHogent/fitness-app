{
  "name": "fitness-app-api",
  "version": "1.0.0",
  "description": "TypeGraphQL API for fitness app",
  "main": "index.js",
  "repository": "https://github.com/EdwardKerckhofHogent/fitness-app",
  "author": "Edward Kerckhof",
  "license": "MIT",
  "scripts": {
    "start": "ts-node-dev --respawn src/index.ts",
    "build": "rimraf ./dist && tsc && copyfiles .env dist",
    "db:migrate": "npx ts-node ./node_modules/.bin/typeorm migration:generate -n Table"
  },
  "dependencies": {
    "apollo-server-express": "^2.9.13",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.4",
    "cors": "^2.8.5",
    "dotenv": "^8.2.0",
    "express": "^4.17.1",
    "graphql": "^14.5.8",
    "jsonwebtoken": "^8.5.1",
    "mysql": "^2.17.1",
    "reflect-metadata": "^0.1.13",
    "type-graphql": "^0.17.5",
    "typeorm": "^0.2.21"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cookie-parser": "^1.4.2",
    "@types/cors": "^2.8.6",
    "@types/express": "^4.17.2",
    "@types/graphql": "^14.5.0",
    "@types/jsonwebtoken": "^8.3.5",
    "@types/node": "^12.12.14",
    "copyfiles": "^2.1.1",
    "rimraf": "^3.0.0",
    "ts-node": "^8.5.4",
    "ts-node-dev": "^1.0.0-pre.44",
    "typescript": "^3.7.3"
  }
}
